@startuml pipeline_overview
!define sub_modules_path ../../../../
!include sub_modules_path/projects/templates/plantuml/activity_diagram.puml
'!define show_constraints
'!define show_notes
'!define show_all

!ifdef show_all
!define show_constraints
!define show_notes
!endif

title AI Requirements Analyzer — Pipeline Overview


start
:receive <doc>.pdf spec; <<$INPUT>>

: (S0) Extractor
  I: <doc>.pdf
    1. PDF → raw text per page and file metadata, 
    2. Page & char limit enforcement
  O: 00_raw_extract.json;
!ifdef show_constraints
note right
  Constraints:
  - Input:  input/<project>/<doc>.pdf
  - Output: artifacts/<project>/00_raw_extract_<doc>.json  [00_raw_extract.json]
  - Limits: max 10 pages, max 30,000 chars
end note
!endif

: (S1) Normalizer
  I: 00_raw_extract.json
    1. ligature replacement and dehyphenation 
    2. LLM Identify item id and heading patterns
  O: 01_normalized.json;

if ((S2) Preflight\n I: 01_normalized.json\n  1.Computes: ID count, duplicate count, extraction-quality score \n O: pass/fail status) then (fail\nscore < 0.80 or < 5 reqs\n emit user guidance)
  stop
endif
!ifdef show_constraints
note right
  Constraint:
    - Gate: score ≥ 0.80 AND req_count ≥ 5 
        (i) Computed based on percentage of duplicates (sections and items) and
            percentage of messy content (tables, graphs that got weirdly extracted)
end note
!endif

: (S3) LLM Structurer
  I: 01_normalized.json
    1. Asks LLM to identify and provide item locations
        (e.g. id: REQ-123 loc: [page: 1, lines: 3-6])
    2. Python resolves the locations, and validates the content
    3. Python computes items' hierarchy number 
    4. Python computes unique ids for change tracking
  O: 03_llm_structured.json;
!ifdef show_notes
note right
  Note:
    - Hierarchy number is used to preserve the spec's structure
      but maintaining flat json (nested are hard to process for LLMs)
    - Unique ids are used to identify changes (e.g. hash(item.content))
end note
!endif

: (S4) LLM Analyzer
  I: 03_llm_structured.json
  I: 01_normalized.json (full text for location resolution)
    1. Python resolves items' locations
    2. Python prepares relevant items and attributes for Pass 3
    3. LLM: Pass 3 - Requirements quality review
    4. Python: Collects flags, metadata and provides report
  O: 04_llm_analyzed.json;

: (S5) Renderer
  I: 04_llm_analyzed.json
    1. Generates single-page HTML dashboard
  O: 05_flag_report.html;
!ifdef show_constraints
note right
  Constraint:
  - Output path: output/<project>/<doc>.html
  - (i) project and doc name derived from input PDF path
end note
!endif

stop

@enduml
