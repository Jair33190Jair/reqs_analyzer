@startuml pipeline_overview
!define sub_modules_path ../../../../
!include sub_modules_path/projects/templates/plantuml/activity_diagram.puml
'!define show_constraints

title AI Requirements Analyzer — Pipeline Overview


start
:receive <doc>.pdf spec; <<$INPUT>>

: (S0) Extractor
  PDF → raw text per page and file metadata, 
  page+char limit enforcement;
!ifdef show_constraints
note right
  Constraints:
  - Input:  input/<project>/<doc>.pdf
  - Output: artifacts/<project>/00_raw_extract_<doc>.json  [00_raw_extract.json]
  - Limits: max 10 pages, max 30,000 chars
end note
!endif

: (S1) Normalizer
  ligature replacement, dehyphenation, 
  item ID and heading pattern recognition;
!ifdef show_constraints
note right
  Constraints:
  - Input:  00_raw_extract_<doc>.json
  - Output: 01_normalized_<doc>.json
end note
!endif

if ((S2) Preflight\n gatekeeper logic (ID count, duplicate detection, messy content score threshold)) then (fail\nscore < 0.80 or < 5 reqs\n emit user guidance)
  stop
endif
!ifdef show_constraints
note right
  Constraints:
    - Input:  01_normalized_text.json
    - Output: 02_after_preflight.json
    - Gate:   score ≥ 0.80 AND req_count ≥ 5
end note
!endif

: (S3) LLM Structurer
  text → uses llm to identify structure (items, headings and locations) 
  → python resolves the locations, validates the content and generates internal ids;
!ifdef show_constraints
note right
  Constraints:
    - Input:  02_after_preflight.json
    - Output: 03_llm_structured.json  [spec.schema.v1]
    - LLM:    called here (cost incurred)
end note
!endif

: (S4) LLM Analyzer
  assess quality, completeness, safety;
!ifdef show_constraints
note right
  Constraints:
    - Input:  03_llm_structured.json
    - Output: 04_llm_analyzed.json  [analysis.schema.v1]
    - LLM:    called here (cost incurred)
end note
!endif

: (S5) Renderer
  JSON → HTML report;
!ifdef show_constraints
note right
  Constraints:
  - Input:  04_llm_analyzed.json
  - Output: 05_report<doc>.html
  - No AI calls — deterministic templating only
end note
!endif

:deliver 05_report<doc>.html; <<$OUTPUT>>
!ifdef show_constraints
note right
  Constraint:
  - Output path: output/<project>/<doc>.html
  - (i) project and doc name derived from input PDF path
end note
!endif
stop

@enduml
