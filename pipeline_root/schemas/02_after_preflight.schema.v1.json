{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["doc_id", "checks", "score", "pass"],
  "properties": {
    "doc_id": { "type": "string" },
    "checks": {
      "type": "object",
      "required": [
        "item_id_count",
        "unique_item_id_count",
        "duplicate_item_ids",
        "sections_count",
        "unique_section_count",
        "duplicate_sections",
        "table_layout_lines",
        "total_lines"
      ],
      "properties": {
        "item_id_count":        { "type": "integer", "minimum": 0 },
        "unique_item_id_count": { "type": "integer", "minimum": 0 },
        "duplicate_item_ids":   { "type": "array", "items": { "type": "string" } },
        "sections_count":       { "type": "integer", "minimum": 0 },
        "unique_section_count": { "type": "integer", "minimum": 0 },
        "duplicate_sections":   { "type": "array", "items": { "type": "string" } },
        "table_layout_lines":   { "type": "integer", "minimum": 0 },
        "total_lines":          { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "score":   { "type": "number", "minimum": 0, "maximum": 1 },
    "pass":    { "type": "boolean" }
  },
  "additionalProperties": false
}
