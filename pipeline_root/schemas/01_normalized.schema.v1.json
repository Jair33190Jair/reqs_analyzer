{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_version": "1.0",
  "type": "object",
  "required": ["source_ref", "normalization", "pages"],
  "properties": {
    "source_ref": {
      "type": "string",
      "description": "Filename of the raw extract JSON this document was produced from."
    },
    "normalization": {
      "type": "object",
      "required": [
        "dehyphenation",
        "ligature_map",
        "line_joining",
        "header_footer_strip",
        "item_id_pattern",
        "heading_pattern"
      ],
      "properties": {
        "dehyphenation":      { "type": "boolean" },
        "ligature_map":       { "type": "boolean" },
        "line_joining":       { "type": "string", "enum": ["soft", "none"] },
        "header_footer_strip":{ "type": "string", "enum": ["heuristic", "none"] },
        "item_id_pattern": {
          "type": "string",
          "description": "Python regex that matches a standalone requirement ID line (e.g. REQ-001)."
        },
        "heading_pattern": {
          "type": ["string", "null"],
          "description": "Python regex that matches a section heading line, or null if not detected."
        }
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page", "text"],
        "properties": {
          "page": { "type": "integer" },
          "text": { "type": "string" }
        }
      }
    }
  }
}
