{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["doc_id", "checks", "score", "pass", "actions"],
  "properties": {
    "doc_id": { "type": "string" },
    "checks": {
      "type": "object",
      "required": [
        "item_id_count",
        "unique_item_id_count",
        "duplicate_item_ids",
        "sections_count",
        "unique_section_count",
        "duplicate_sections",
        "possible_table_layout"
      ],
      "properties": {
        "item_id_count":        { "type": "integer", "minimum": 0 },
        "unique_item_id_count": { "type": "integer", "minimum": 0 },
        "duplicate_item_ids":   { "type": "array", "items": { "type": "string" } },
        "sections_count":       { "type": "integer", "minimum": 0 },
        "unique_section_count": { "type": "integer", "minimum": 0 },
        "duplicate_sections":   { "type": "array", "items": { "type": "string" } },
        "possible_table_layout":{ "type": "boolean" }
      },
      "additionalProperties": false
    },
    "score":   { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "pass":    { "type": "boolean" },
    "actions": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
  },
  "additionalProperties": false
}
